@page
@model OrderSuccessModel
@{
    ViewData["Title"] = "Order Received";
}

<ol id="orderProcess">
    <li><span class="step-number">1</span>Choose Item</li>
    <li><span class="step-number">2</span>Details &amp; Submit</li>
    <li class="current"><span class="step-number">3</span>Receipt</li>
</ol>

<h1>Thank You for Your Order!</h1>

@if (Model.NoEmail == true)
{
    <p class="warning">Your order was received, but we could not send a confirmation email. Please check back soon!</p>
}
else
{
    <p>Thank you, we have received your order@(Model.ProductName != null ? $" for {Model.ProductName}" : "")!</p>
    
    @if (Model.Quantity.HasValue && Model.Total != null)
    {
        <div class="order-summary">
            <p><strong>Quantity:</strong> @Model.Quantity unit(s)</p>
            <p><strong>Total:</strong> $@Model.Total</p>
        </div>
    }
    
    <p>We will contact you if we have questions about your order. Thanks!</p>
}

<a href="~/" class="order-button">Continue Shopping</a>
